# LLM-Defanc Gateway Configuration

# Database Configuration
# To use PostgreSQL, set DATABASE_URL to postgresql+asyncpg://user:pass@host:port/dbname
# Otherwise, it falls back to a local SQLite database automatically.
DATABASE_URL=sqlite+aiosqlite:///./llm_defense.db

# Redis Configuration (for Rate Limiting)
# If Redis is unavailable, falls back to local in-memory sliding window rate limiting.
REDIS_URL=redis://localhost:6379/0

# Security Configuration
JWT_SECRET=supersecretenterprise-leveltokensigningkey1029384756!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# LLM Gateway Configuration
# Set LLM_PROVIDER to "openai", "gemini", or "mock" (default for offline testing)
LLM_PROVIDER=mock
LLM_API_KEY=mock-api-key

# Gateway Policies
# Rate limiting configuration (requests per minute per user)
RATE_LIMIT_PER_MINUTE=30

# PII Policy: "redact" (replace PII with placeholders) or "block" (reject prompt with 400 error)
PII_POLICY=redact

# Active PII entities to detect (comma-separated)
# Supported: EMAIL_ADDRESS, PHONE_NUMBER, CREDIT_CARD, US_SSN, IP_ADDRESS, SECRET_KEY
PII_ENTITIES=EMAIL_ADDRESS,PHONE_NUMBER,CREDIT_CARD,US_SSN,IP_ADDRESS,SECRET_KEY

# Prompt Injection Threshold (0.0 to 1.0)
# Dynamic prompt injection heuristic sensitivity threshold (lower is more sensitive)
PROMPT_INJECTION_THRESHOLD=0.5
